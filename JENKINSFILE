pipeline {
    agent none

    stages {
        stage('Checkout') {
            agent any
            steps {
                sh 'echo "Descargando Git"'
                git url: 'https://github.com/pdejulian/calculadora.git'
                stash name: 'codigo', includes: '**/*'
            }
        }
        stage('Test y Analisis') {
            parallel {
        stage('Unit') {
            agent { label 'agent2' }
            steps {
                unstash 'codigo'
                sh '''
                    echo "Lanzando Unit y generando reportes JUnit y Coverage"
                    whoami && hostname && echo $WORKSPACE
                    export PYTHONPATH="$WORKSPACE"
                    coverage run --branch -m pytest --junitxml=result-unit.xml test/unit
                    coverage xml -o coverage.xml
                '''
                junit 'result-unit.xml'
            }
        }

        stage('Static') {
            agent { label 'agent1' }
            steps {
                unstash 'codigo'
                sh 'echo "Preparando Flake8"'
                script {
                    def flake8Output = sh(
                        script: '''
                            python3 -m flake8 app test --format="%(path)s:%(row)d:%(col)d: %(code)s %(text)s" || true
                        ''',
                        returnStdout: true
                    ).trim()

                    writeFile file: 'flake8.out', text: flake8Output

                    def findings = flake8Output ? flake8Output.readLines().size() : 0

                    echo "Flake8 findings: ${findings}"

                    if (findings >= 10) {
                        catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                            error("Analisis estatico unhealthy: ${findings} findings")
                        }
                    } else if (findings >= 8) {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                            error("Analisis estatico unstable: ${findings} findings")
                        }
                    } else {
                        echo "Analisis estatico OK: ${findings} findings"
                    }
                }
            } 
        }
        stage('Security') {
            agent { label 'agent1' }
            steps {
                unstash 'codigo'
                script {
                    sh '''
                        python3 -m bandit -r app || true
                    '''
                    def findings = sh(
                        script: '''python3 -c "import json; print(len(json.load(open('bandit.json')).get('results', [])))"''',
                        returnStdout: true
                    ).trim().toInteger()
                    echo "Bandit findings: ${findings}"

                    if (findings >= 4) {
                        catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                            error("Analisis de seguridad unhealthy: ${findings} findings")
                        }
                    } else if (findings >= 2) {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                        error("Analisis de seguridad unstable: ${findings} findings")
                        }
                    } else {
                        echo "Analisis de seguridad OK: ${findings} findings"
                    }
                }
            }
        }
        stage('Performance') {
            agent { label 'agent2' }
            steps {
                unstash 'codigo'
                sh '''
                    echo "Preparando Flask"
                    whoami && hostname && echo $WORKSPACE
                    export PYTHONPATH="$WORKSPACE"
                    nohup python3 -m flask --app app/api.py run &
                    echo "Esperando a Flask"
                    for i in $(seq 1 30); do
                        if curl -s http://127.0.0.1:5000/ >/dev/null 2>&1; then
                        break
                        fi
                        sleep 2
                        done
                        
                    echo "Ejecutando JMeter 5.6.3"
                    /opt/jmeter/bin/jmeter -n \
                    -t test/jmeter/flask.jmx \
                    -l test/jmeter/result.jtl
                    
                    echo "Comprobando errores reales en el JTL"
                    ERRORS=$(awk -F',' 'NR>1 && $9=="false" {c++} END {print c+0}' test/jmeter/result.jtl)
                    echo "Errores detectados: $ERRORS"

                    if [ "$ERRORS" -gt 0 ]; then
                        echo "Hay errores en JMeter"
                        exit 1
                    fi
                '''
                
            perfReport sourceDataFiles: 'test/jmeter/result.jtl'
        }
        post {
            always {
                sh '''
                    echo "Deteniendo Flask"
                    pkill -f "python3 app.py" || true
                '''
            }
        }
    }
        stage('Rest') {
            agent { label 'agent1' }
            steps {
                unstash 'codigo'
                sh '''
                    echo "Ejecutando Flask y Wiremock"
                    whoami && hostname && echo $WORKSPACE
                    export FLASK_APP=app/api.py
                    export FLASK_ENV=development
                    nohup python3 -m flask --app app/api.py run &
                    nohup /usr/bin/java -jar /opt/wiremock-standalone.jar --port 9090 --root-dir test/wiremock/ &
                    sleep 20
                    pytest --junitxml=result-rest.xml test/rest
                '''
                    }
                }
            }
        }
            stage('Coverage') {
            agent { label 'agent2' }
            steps {
                unstash 'codigo'
                sh '''
                echo "Publicando cobertura"
                whoami && hostname && echo $WORKSPACE
            '''
            recordCoverage(
                tools: [[parser: 'COBERTURA', pattern: 'coverage.xml']],
                enabledForFailure: true,
                qualityGates: [
                    [metric: 'LINE', threshold: 85.0, baseline: 'PROJECT', unstable: false],
                    [metric: 'LINE', threshold: 95.0, baseline: 'PROJECT', unstable: true],
                    [metric: 'BRANCH', threshold: 80.0, baseline: 'PROJECT', unstable: false],
                    [metric: 'BRANCH', threshold: 90.0, baseline: 'PROJECT', unstable: true]
                    ]
                )
            }
        }
    }
}
